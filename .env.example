# Azure AI Document Intelligence (for CV Parsing)
# Get from: https://portal.azure.com → Azure AI services → Document Intelligence
AZURE_DOCUMENT_INTELLIGENCE_ENDPOINT=https://<your-resource>.cognitiveservices.azure.com/
AZURE_DOCUMENT_INTELLIGENCE_KEY=

# Azure AI Language (for Skill Extraction via Key Phrase Extraction)
# Get from: https://portal.azure.com → Azure AI services → Language service
AZURE_LANGUAGE_ENDPOINT=https://<your-resource>.cognitiveservices.azure.com/
AZURE_LANGUAGE_KEY=

# App Settings
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Auth + Database
DATABASE_URL="file:./dev.db"
AUTH_SECRET="replace-with-a-long-random-secret"
